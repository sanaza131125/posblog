<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blogger Scheduler</title>
  <link rel="stylesheet" href="style.css">
  <script src="https://apis.google.com/js/api.js"></script>
</head>
<body>
  <div class="container">
    <h1>📌 Blogger Scheduler</h1>
    <button id="loginBtn">Login Google</button>
    <form id="postForm">
      <input type="text" id="title" placeholder="Judul" required>
      <textarea id="content" placeholder="Isi artikel" required></textarea>
      <input type="text" id="imageUrl" placeholder="URL Gambar">
      <input type="text" id="labels" placeholder="Label (pisahkan dengan koma)">
      <input type="text" id="hashtags" placeholder="Hashtag">
      <input type="datetime-local" id="scheduleTime">
      <button type="submit">Posting</button>
    </form>
  </div>
  <script src="app.js"></script>
</body>
</html>
